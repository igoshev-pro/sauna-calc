# --- Mongo root (для контейнера БД) ---
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=admin123

# --- Backend подключается к mongo по имени сервиса "mongo" ---
MONGO_URI=mongodb://admin:sauna123@mongo:27017/sauna_calc?authSource=admin

# --- JWT (ОБЯЗАТЕЛЬНО поменять!) ---
JWT_SECRET=your_jwt_secret_here_change_in_prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_here_change_in_prod
JWT_REFRESH_EXPIRES_IN=7d

# --- Публичные адреса (замени SERVER_IP на реальный IP сервера) ---
FRONTEND_URL=http://SERVER_IP:3000
NEXT_PUBLIC_API_URL=http://SERVER_IP:3001/api